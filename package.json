{
  "name": "node_plawright_test",
  "version": "1.0.0",
  "main": "dist/electron/main/index.js",
  "scripts": {
    "build:ts": "tsc -p tsconfig.electron.json",
    "build:copy": "copyfiles electron/renderer/* dist/electron/renderer -u 1",
    "electron:dev": "npm run build:ts && npm run build:copy && electron .",
    "electron:build": "npm run build:ts && npm run build:copy && electron-builder",
    "electron:build:portable": "npm run build:ts && npm run build:copy && electron-builder --win portable",
    "prebuild": "npm run build:ts && npm run build:copy"
  },
  "build": {
    "appId": "com.example.automation",
    "productName": "Browser Automation",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraFiles": [],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.icns"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development"
    }
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "copyfiles": "^2.4.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}
