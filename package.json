{
  "name": "node_plawright_test",
  "version": "1.0.0",
  "main": "dist/electron/main/index.js",
  "scripts": {
    "electron:dev": "npx tsc -p tsconfig.electron.json && node -e \"const fs=require('fs'),path=require('path');fs.readdirSync('electron/renderer').forEach(f=>fs.copyFileSync(path.join('electron/renderer',f),path.join('dist/electron/renderer',f)))\" && electron .",
    "electron:build": "npx tsc -p tsconfig.electron.json && node -e \"const fs=require('fs'),path=require('path');fs.readdirSync('electron/renderer').forEach(f=>fs.copyFileSync(path.join('electron/renderer',f),path.join('dist/electron/renderer',f)))\" && electron-builder",
    "electron:build:portable": "npx tsc -p tsconfig.electron.json && node -e \"const fs=require('fs'),path=require('path');fs.readdirSync('electron/renderer').forEach(f=>fs.copyFileSync(path.join('electron/renderer',f),path.join('dist/electron/renderer',f)))\" && electron-builder --win portable"
  },
  "build": {
    "appId": "com.example.automation",
    "productName": "Browser Automation",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraFiles": [],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}
